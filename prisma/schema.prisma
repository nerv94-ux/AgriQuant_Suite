generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  ADMIN
  USER
}

enum ApiProvider {
  GEMINI
  ECOUNT
  NAVER
  GARAK
}

model User {
  id              String          @id @default(cuid())
  name            String?
  email           String?         @unique
  emailVerified  DateTime?
  image           String?

  role            UserRole        @default(USER)
  approvalStatus ApprovalStatus  @default(PENDING)
  // 어떤 '프로그램(앱)'을 통해 가입/로그인했는지 추적하기 위한 값
  // 예: registeredAppId = "naver-shopping", "kaksdong-market" 등
  registeredAppId String?

  accounts        Account[]
  sessions        Session[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token    String?
  access_token     String?
  expires_at       Int?
  token_type       String?
  scope            String?
  id_token         String?
  session_state    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model ApiCallLog {
  id            String   @id @default(cuid())
  requestId     String   @unique
  source        String
  ok            Boolean
  durationMs    Int
  timestamp     DateTime
  appId         String?
  errorCategory String?
  message       String?
  extra         String?  // JSON 직렬화 저장(SQLite 호환)

  createdAt     DateTime @default(now())
}

model ApiConfig {
  id              String      @id @default(cuid())
  provider        ApiProvider @unique
  enabled         Boolean     @default(true)
  defaultModel    String?
  timeoutMs       Int?
  temperature     Float?
  maxOutputTokens Int?
  updatedByEmail  String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model ApiSecret {
  id             String      @id @default(cuid())
  provider       ApiProvider
  keyName        String
  encryptedValue String
  iv             String
  authTag        String
  updatedByEmail String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([provider, keyName])
}

model ApiAuditLog {
  id         String      @id @default(cuid())
  provider   ApiProvider
  action     String
  actorEmail String?
  detail     String?
  createdAt  DateTime    @default(now())
}

